{
  "ReverseProxy": {
    "Routes": {
      "user-vehicles-route": {
        "ClusterId": "user-vehicles-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/user-vehicles/{**catch-all}"
        }
      },
      "vehicles-catalog-route": {
        "ClusterId": "vehicles-catalog-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/vehicles-catalog/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "user-vehicles-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5077/"
          }
        }
      },
      "vehicles-catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:4000/"
          }
        }
      }
    }
  }
}
